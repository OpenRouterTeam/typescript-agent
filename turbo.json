{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "src/**", "tsconfig.json"],
      "outputs": ["esm/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "src/**", "tests/**", "tsconfig.json"],
      "outputs": []
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "src/**", "tests/**"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "tests/unit/**",
        "vitest.config.ts",
        "tsconfig.json"
      ],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true,
      "env": ["OPENROUTER_API_KEY"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "tests/e2e/**",
        "vitest.config.ts",
        "tsconfig.json"
      ],
      "outputs": [],
      "cache": false,
      "env": ["OPENROUTER_API_KEY"]
    }
  }
}
